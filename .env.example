# =============================================================================
# JG-SINAPTOR — Bus de Eventos
# =============================================================================
# Copiar a .env y ajustar valores

# -----------------------------------------------------------------------------
# Global
# -----------------------------------------------------------------------------
APP_NAME=jg-sinaptor
ENVIRONMENT=dev

# -----------------------------------------------------------------------------
# Puertos host (convención 90XY: X=5 sinaptor, Y=servicio)
# Y=2 backend, Y=3 akhq, Y=6 mongodb, Y=8 kafka
# -----------------------------------------------------------------------------
BACKEND_PORT=9052
AKHQ_PORT=9053
MONGODB_PORT=9056
KAFKA_PORT=9058

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
MONGO_DB=jg_sinaptor
MONGO_USER=sinaptor
MONGO_PASS=CHANGE_ME

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------
KAFKA_TOPICS=botellas-events,tunnels-events,dlq-events
CLUSTER_ID=jg-sinaptor-cluster-001

# -----------------------------------------------------------------------------
# Gateway WebSocket (shell-gw)
# -----------------------------------------------------------------------------
GATEWAY_WS_URL=http://host.docker.internal:3000
ETER_INTERNAL_SECRET=CHANGE_ME
